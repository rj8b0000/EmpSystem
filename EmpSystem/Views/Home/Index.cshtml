@model PaginatedList<EmpSystem.ViewModel.EmployeeViewModal>;
@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="~/css/home.css"/>

<!-- Welcome Banner -->
<div class="welcome-banner">
    <div class="welcome-text">
        <h3>Welcome back, Admin 👋</h3>
        <p>Here's what's happening in your HR system today.</p>
    </div>
    <div class="welcome-date">
        <div class="date-day" id="dateDay"></div>
        <div class="date-month" id="dateMonth"></div>
    </div>
</div>

<!-- Quick Actions -->
<div class="section-title">Quick Actions</div>
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="action-card">
            <div class="action-card-icon stat-icon-blue">
                <i class="bi bi-person-plus" style="color:#4f8ef7;"></i>
            </div>
            <h6>Add Employee</h6>
            <p>Register a new employee and assign them to a department.</p>
            <a asp-controller="Employee" asp-action="Add" class="btn-action btn-action-blue">
                <i class="bi bi-plus-lg"></i> Add Now
            </a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="action-card">
            <div class="action-card-icon stat-icon-green">
                <i class="bi bi-people" style="color:#10b981;"></i>
            </div>
            <h6>All Employees</h6>
            <p>Browse, search, and manage your entire employee roster.</p>
            <a asp-controller="Employee" asp-action="Index" class="btn-action btn-action-outline">
                <i class="bi bi-arrow-right"></i> View List
            </a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="action-card">
            <div class="action-card-icon stat-icon-amber">
                <i class="bi bi-building-add" style="color:#f59e0b;"></i>
            </div>
            <h6>Add Department</h6>
            <p>Create a new department and start assigning employees.</p>
            <a asp-controller="Department" asp-action="Add" class="btn-action btn-action-blue">
                <i class="bi bi-plus-lg"></i> Add Now
            </a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="action-card">
            <div class="action-card-icon stat-icon-purple">
                <i class="bi bi-diagram-3" style="color:#8b5cf6;"></i>
            </div>
            <h6>All Departments</h6>
            <p>View and manage all departments across your organisation.</p>
            <a asp-controller="Department" asp-action="Index" class="btn-action btn-action-outline">
                <i class="bi bi-arrow-right"></i> View List
            </a>
        </div>
    </div>
</div>

<!-- Recent Activity -->
<div class="section-title">Recent Activity</div>
<div class="activity-card">
    <div class="activity-header">
        <h6><i class="bi bi-clock-history me-2" style="color:#4f8ef7;"></i>Latest Updates</h6>
        <a asp-controller="Employee" asp-action="Index"
           style="font-size:0.78rem; color:#4f8ef7; text-decoration:none; font-weight:600;">
            View all <i class="bi bi-arrow-right"></i>
        </a>
    </div>

    @if (ViewBag.RecentEmployees != null)
    {
        var colors = new[] { "#4f8ef7","#10b981","#f59e0b","#ec4899","#8b5cf6" };
        int idx = 0;
        foreach (var emp in ViewBag.RecentEmployees)
        {
            var color = colors[idx % colors.Length];
            <div class="activity-item">
                <div class="activity-dot" style="background:@color;"></div>
                <div class="activity-text">
                    <strong>@emp.FirstName @emp.LastName</strong> was added
                    to <strong>@emp.DepartmentName</strong>
                </div>
                <div class="activity-time">@emp.DateOfBirth.ToString("MMM dd")</div>
            </div>
            idx++;
        }
    }
    else
    {
        <div class="activity-item">
            <div class="activity-dot" style="background:#e2e8f0;"></div>
            <div class="activity-text" style="color:#94a3b8;">No recent activity to show.</div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Live date in welcome banner
        const now = new Date();
        document.getElementById('dateDay').textContent = now.getDate();
        document.getElementById('dateMonth').textContent =
            now.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
    </script>
}