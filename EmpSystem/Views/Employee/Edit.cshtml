@model EmpSystem.ViewModel.EmployeeViewModal
@{
    ViewData["Title"] = "Edit Employee";
}
<link rel="stylesheet" href="~/css/employee-form.css" />

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">

        <!-- Page Heading -->
        <div class="d-flex align-items-center gap-2 mb-3">
            <a asp-controller="Employee" asp-action="Index"
               class="btn-cancel" style="padding:7px 14px; border-radius:8px;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h4 class="mb-0 fw-bold" style="font-size:1.1rem; color:#1e2a3a;">
                    Edit Employee
                </h4>
                <p class="mb-0 text-muted" style="font-size:0.78rem;">
                    Update the details for <strong>@Model.FirstName @Model.LastName</strong>
                </p>
            </div>
        </div>

        <div class="form-card">

            <!-- Card Header -->
            <div class="form-card-header">
                <div class="header-icon"><i class="bi bi-pencil-square"></i></div>
                <div>
                    <h5>Employee Information</h5>
                    <p>Modify personal & contact details below</p>
                </div>
            </div>

            <!-- Card Body -->
            <div class="form-card-body">
                <form asp-action="Edit" asp-controller="Employee" method="post">
                    @Html.AntiForgeryToken()
                    <input hidden asp-for="EmployeeId" />

                    <!-- PERSONAL INFO -->
                    <div class="section-divider">
                        <i class="bi bi-person me-1"></i> Personal Information
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label">First Name</label>
                            <input asp-for="FirstName" type="text" class="form-control" placeholder="e.g. John"/>
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label">Last Name</label>
                            <input asp-for="LastName" type="text" class="form-control" placeholder="e.g. Smith"/>
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-7">
                            <label asp-for="Email" class="form-label">Email Address</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Email" type="email" class="form-control" placeholder="john@example.com"/>
                            </div>
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-5">
                            <label asp-for="DateOfBirth" class="form-label">Date of Birth</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control"/>
                            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label d-block">Gender</label>
                            <div class="radio-group">
                                <div class="radio-option">
                                    <input type="radio" id="genderMale" asp-for="Gender" value="Male"/>
                                    <label for="genderMale">
                                        <i class="bi bi-gender-male"></i> Male
                                    </label>
                                </div>
                                <div class="radio-option">
                                    <input type="radio" id="genderFemale" asp-for="Gender" value="Female"/>
                                    <label for="genderFemale">
                                        <i class="bi bi-gender-female"></i> Female
                                    </label>
                                </div>
                                <div class="radio-option">
                                    <input type="radio" id="genderOther" asp-for="Gender" value="Other"/>
                                    <label for="genderOther">
                                        <i class="bi bi-gender-ambiguous"></i> Other
                                    </label>
                                </div>
                            </div>
                            <span asp-validation-for="Gender" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DepartmentId" class="form-label">Department</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-diagram-3"></i></span>
                                <select asp-for="DepartmentId" class="form-select"
                                        asp-items="ViewBag.Departments">
                                    <option value="">-- Select Department --</option>
                                </select>
                            </div>
                            <span asp-validation-for="DepartmentId" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- CONTACT INFO -->
                    <div class="section-divider">
                        <i class="bi bi-telephone me-1"></i> Contact Details
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                            <input asp-for="PhoneNumber" type="tel" class="form-control"
                                   placeholder="+1 (555) 000-0000"/>
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Address" class="form-label">Address</label>
                        <textarea asp-for="Address" class="form-control" rows="3"
                                  placeholder="Street, City, State, ZIP"></textarea>
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <!-- STATUS -->
                    <div class="section-divider">
                        <i class="bi bi-toggle-on me-1"></i> Employment Status
                    </div>

                    <div class="mb-4">
                        <label class="form-label d-block">Is Active?</label>
                        <div class="radio-group">
                            <div class="radio-option active-yes">
                                <input type="radio" id="isActiveYes" name="IsActive"
                                       value="true" @(Model.IsActive ? "checked" : "")/>
                                <label for="isActiveYes">
                                    <i class="bi bi-check-circle"></i> Active
                                </label>
                            </div>
                            <div class="radio-option active-no">
                                <input type="radio" id="isActiveNo" name="IsActive"
                                       value="false" @(!Model.IsActive ? "checked" : "")/>
                                <label for="isActiveNo">
                                    <i class="bi bi-x-circle"></i> Inactive
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="IsActive" class="text-danger"></span>
                    </div>

                    <!-- ACTIONS -->
                    <div class="d-flex align-items-center gap-3 pt-3 border-top">
                        <button type="submit" class="btn-save">
                            <i class="bi bi-check-lg"></i> Save Changes
                        </button>
                        <a asp-controller="Employee" asp-action="Index" class="btn-cancel">
                            <i class="bi bi-x"></i> Cancel
                        </a>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
