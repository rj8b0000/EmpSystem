@model EmpSystem.ViewModel.EmployeeViewModal
@{
    ViewData["Title"] = "Add Employee";
}

<link rel="stylesheet" href="~/css/employee-form.css" />

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">

        <!-- Page heading -->
        <div class="d-flex align-items-center gap-2 mb-3">
            <a asp-controller="Employee" asp-action="Index" class="btn-cancel" style="padding: 7px 14px; border-radius: 8px;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h4 class="mb-0 fw-bold" style="font-size:1.1rem; color:#1e2a3a;">Add New Employee</h4>
                <p class="mb-0 text-muted" style="font-size:0.78rem;">Fill in the details below to register a new employee</p>
            </div>
        </div>

        <div class="form-card">
            <!-- Card Header -->
            <div class="form-card-header">
                <div class="header-icon"><i class="bi bi-person-plus"></i></div>
                <div>
                    <h5>Employee Information</h5>
                    <p>Personal & contact details</p>
                </div>
            </div>

            <!-- Card Body -->
            <div class="form-card-body">
                <form asp-controller="Employee" asp-action="Add" method="post">
                    @Html.AntiForgeryToken()

                    <!-- PERSONAL INFO -->
                    <div class="section-divider"><i class="bi bi-person me-1"></i> Personal Information</div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label">First Name</label>
                            <input asp-for="FirstName" class="form-control" placeholder="e.g. John"/>
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label">Last Name</label>
                            <input asp-for="LastName" class="form-control" placeholder="e.g. Smith"/>
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-7">
                            <label asp-for="Email" class="form-label">Email Address</label>
                            <div class="input-group">
                                <span class="input-group-text" style="background:#fafbfc; border:1.5px solid #e2e8f0; border-right:0; border-radius:9px 0 0 9px; color:#94a3b8;">
                                    <i class="bi bi-envelope"></i>
                                </span>
                                <input asp-for="Email" type="email" class="form-control" placeholder="john@example.com"
                                       style="border-left:0; border-radius:0 9px 9px 0;"/>
                            </div>
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="col-md-5">
                            <label asp-for="DateOfBirth" class="form-label">Date of Birth</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control"/>
                            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label d-block">Gender</label>
                        <div class="radio-group">
                            <div class="radio-option">
                                <input type="radio" id="genderMale" asp-for="Gender" value="Male"/>
                                <label for="genderMale"><i class="bi bi-gender-male"></i> Male</label>
                            </div>
                            <div class="radio-option">
                                <input type="radio" id="genderFemale" asp-for="Gender" value="Female"/>
                                <label for="genderFemale"><i class="bi bi-gender-female"></i> Female</label>
                            </div>
                            <div class="radio-option">
                                <input type="radio" id="genderOther" asp-for="Gender" value="Other"/>
                                <label for="genderOther"><i class="bi bi-gender-ambiguous"></i> Other</label>
                            </div>
                        </div>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>

                    <!-- CONTACT INFO -->
                    <div class="section-divider"><i class="bi bi-telephone me-1"></i> Contact Details</div>

                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                        <div class="input-group">
                            <span class="input-group-text" style="background:#fafbfc; border:1.5px solid #e2e8f0; border-right:0; border-radius:9px 0 0 9px; color:#94a3b8;">
                                <i class="bi bi-telephone"></i>
                            </span>
                            <input asp-for="PhoneNumber" type="tel" class="form-control" placeholder="+1 (555) 000-0000"
                                   style="border-left:0; border-radius:0 9px 9px 0;"/>
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Address" class="form-label">Address</label>
                        <textarea asp-for="Address" class="form-control" rows="3" placeholder="Street, City, State, ZIP"></textarea>
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <!-- STATUS -->
                    <div class="section-divider"><i class="bi bi-toggle-on me-1"></i> Employment Status</div>
                    <div class="mb-4">
                        <label asp-for="DepartmentId" class="form-label">Department</label>
                        <div class="input-group">
                            <span class="input-group-text" style="background:#fafbfc; border:1.5px solid #e2e8f0; border-right:0; border-radius:9px 0 0 9px; color:#94a3b8;">
                                <i class="bi bi-diagram-3"></i>
                            </span>
                            <select asp-for="DepartmentId" class="form-select"
                                    asp-items="ViewBag.Departments"
                                    style="border-left:0; border-radius:0 9px 9px 0;">
                                <option value="">-- Select Department --</option>
                            </select>
                        </div>
                        <span asp-validation-for="DepartmentId" class="text-danger"></span>
                    </div>
                    <div class="mb-4">
                        <label class="form-label d-block">Is Active?</label>
                        <div class="radio-group">
                            <div class="radio-option active-yes">
                                <input type="radio" id="isActiveYes" asp-for="IsActive" value="true" checked/>
                                <label for="isActiveYes"><i class="bi bi-check-circle"></i> Active</label>
                            </div>
                            <div class="radio-option active-no">
                                <input type="radio" id="isActiveNo" asp-for="IsActive" value="false"/>
                                <label for="isActiveNo"><i class="bi bi-x-circle"></i> Inactive</label>
                            </div>
                        </div>
                    </div>

                    <!-- ACTIONS -->
                    <div class="d-flex align-items-center gap-3 pt-2 border-top" style="margin-top:8px; padding-top:20px!important;">
                        <button type="submit" class="btn-save">
                            <i class="bi bi-check-lg"></i> Save Employee
                        </button>
                        <a asp-controller="Employee" asp-action="Index" class="btn-cancel">
                            <i class="bi bi-x"></i> Cancel
                        </a>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}