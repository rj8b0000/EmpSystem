@model EmpSystem.ViewModel.DepartmentViewModal
@{
    ViewData["Title"] = "Edit Department";
}

<link rel="stylesheet" href="~/css/department-form.css" />


<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">

        <!-- Page heading -->
        <div class="d-flex align-items-center gap-2 mb-3">
            <a asp-controller="Department" asp-action="Index" class="btn-cancel" style="padding: 7px 14px; border-radius: 8px;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h4 class="mb-0 fw-bold" style="font-size:1.1rem; color:#1e2a3a;">Edit Department</h4>
            </div>
        </div>

        <div class="form-card">
            <!-- Card Header -->
            <div class="form-card-header">
                <div class="header-icon"><i class="bi bi-person-plus"></i></div>
                <div>
                    <h5>Department name</h5>
                </div>
            </div>

            <!-- Card Body -->
            <div class="form-card-body">
                <form asp-controller="Department" asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input hidden asp-for="DepartmentId"/>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="DepartmentName" class="form-label">Department Name</label>
                            <input asp-for="DepartmentName" class="form-control" placeholder="e.g. Marketing"/>
                            <span asp-validation-for="DepartmentName" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- ACTIONS -->
                    <div class="d-flex align-items-center gap-3 pt-2 border-top" style="margin-top:8px; padding-top:20px!important;">
                        <button type="submit" class="btn-save">
                            <i class="bi bi-check-lg"></i> Save Changes
                        </button>

                        <a asp-controller="Employee" asp-action="Index" class="btn-cancel">
                            <i class="bi bi-x"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}