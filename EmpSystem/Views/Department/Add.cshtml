@model EmpSystem.ViewModel.DepartmentViewModal
@{
    ViewData["Title"] = "Add Department";
}

<style>
    .form-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }

    .form-card-header {
        background: #1e2a3a;
        padding: 20px 28px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .form-card-header .header-icon {
        width: 40px; height: 40px;
        background: rgba(79,142,247,0.2);
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        color: #4f8ef7;
        font-size: 1.1rem;
    }

    .form-card-header h5 {
        color: #fff;
        font-weight: 700;
        margin: 0;
        font-size: 1rem;
    }

    .form-card-header p {
        color: rgba(255,255,255,0.45);
        margin: 0;
        font-size: 0.75rem;
    }

    .form-card-body {
        padding: 28px;
    }

    .section-divider {
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #94a3b8;
        padding-bottom: 10px;
        border-bottom: 1px solid #f0f4f8;
        margin-bottom: 20px;
        margin-top: 8px;
    }

    .form-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
    }

    .form-control, .form-select {
        border: 1.5px solid #e2e8f0;
        border-radius: 9px;
        font-size: 0.875rem;
        padding: 10px 14px;
        color: #1a202c;
        background: #fafbfc;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-control:focus, .form-select:focus {
        border-color: #4f8ef7;
        box-shadow: 0 0 0 3px rgba(79,142,247,0.12);
        background: #fff;
    }

    /* Custom Radio */
    .radio-group {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .radio-option {
        flex: 1;
        min-width: 100px;
    }

    .radio-option input[type="radio"] {
        display: none;
    }

    .radio-option label {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        padding: 10px 14px;
        border: 1.5px solid #e2e8f0;
        border-radius: 9px;
        font-size: 0.82rem;
        font-weight: 500;
        color: #64748b;
        background: #fafbfc;
        cursor: pointer;
        transition: all 0.2s;
        width: 100%;
        text-align: center;
    }

    .radio-option label i {
        font-size: 0.95rem;
    }

    .radio-option input[type="radio"]:checked + label {
        border-color: #4f8ef7;
        background: rgba(79,142,247,0.08);
        color: #4f8ef7;
        font-weight: 600;
    }

    /* Active Status radio - green accent */
    .radio-option.active-yes input[type="radio"]:checked + label {
        border-color: #10b981;
        background: rgba(16,185,129,0.08);
        color: #10b981;
    }

    .radio-option.active-no input[type="radio"]:checked + label {
        border-color: #ef4444;
        background: rgba(239,68,68,0.08);
        color: #ef4444;
    }

    /* Buttons */
    .btn-save {
        background: #4f8ef7;
        color: #fff;
        border: none;
        border-radius: 9px;
        padding: 11px 28px;
        font-size: 0.875rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: background 0.2s, transform 0.1s;
    }

    .btn-save:hover {
        background: #3b7de8;
        color: #fff;
        transform: translateY(-1px);
    }

    .btn-cancel {
        background: #f0f4f8;
        color: #64748b;
        border: none;
        border-radius: 9px;
        padding: 11px 24px;
        font-size: 0.875rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: background 0.2s;
        text-decoration: none;
    }

    .btn-cancel:hover {
        background: #e2e8f0;
        color: #374151;
    }

    .text-danger {
        font-size: 0.75rem;
        margin-top: 4px;
    }
</style>

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">

        <!-- Page heading -->
        <div class="d-flex align-items-center gap-2 mb-3">
            <a asp-controller="Department" asp-action="Index" class="btn-cancel" style="padding: 7px 14px; border-radius: 8px;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div>
                <h4 class="mb-0 fw-bold" style="font-size:1.1rem; color:#1e2a3a;">Add New Department</h4>
            </div>
        </div>

        <div class="form-card">
            <!-- Card Header -->
            <div class="form-card-header">
                <div class="header-icon"><i class="bi bi-person-plus"></i></div>
                <div>
                    <h5>Department name</h5>
                </div>
            </div>

            <!-- Card Body -->
            <div class="form-card-body">
                <form asp-controller="Department" asp-action="Add" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="DepartmentName" class="form-label">Department Name</label>
                            <input asp-for="DepartmentName" class="form-control" placeholder="e.g. Marketing"/>
                            <span asp-validation-for="DepartmentName" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- ACTIONS -->
                    <div class="d-flex align-items-center gap-3 pt-2 border-top" style="margin-top:8px; padding-top:20px!important;">
                        <button type="submit" class="btn-save">
                            <i class="bi bi-check-lg"></i> Save Department
                        </button>

                        <a asp-controller="Employee" asp-action="Index" class="btn-cancel">
                            <i class="bi bi-x"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}